{
  "name": "fp-frontend",
  "description": "Klient for FPSAK",
  "main": "./dist/index.js",
  "version": "0.0.0",
  "packageManager": "yarn@4.17.0",
  "author": "Nav",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navikt/fp-frontend.git"
  },
  "scripts": {
    "build": "turbo run build",
    "build:storybook": "turbo run build:storybook && yarn storybook-create-deploy-folder",
    "test": "turbo run test --concurrency=5",
    "eslint": "turbo run eslint",
    "eslint:fix": "turbo run eslint:fix",
    "prettier:fix": "turbo run prettier:fix",
    "stylelint": "turbo run stylelint",
    "tsc": "turbo run tsc",
    "ci": "turbo run build test",
    "clean": "turbo run clean",
    "dev": "turbo run dev --filter=@navikt/fp-frontend",
    "dev-avdelingsleder": "turbo run dev --filter=@navikt/fp-avdelingsleder",
    "dev-journalforing": "turbo run dev --filter=@navikt/fp-journalforing",
    "storybook-create-deploy-folder": "node scripts/create-storybook-index.mjs",
    "generate": "turbo run generate --filter @navikt/fp-types",
    "generate:local": "turbo run generate:local --filter @navikt/fp-types",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/**/*",
    "packages/**/*"
  ],
  "devDependencies": {
    "@navikt/aksel-stylelint": "8.14.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/react": "10.4.6",
    "@testing-library/jest-dom": "6.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.23.0",
    "lint-staged": "17.0.8",
    "prettier": "3.9.3",
    "storybook": "10.4.6",
    "stylelint": "17.14.0",
    "stylelint-order": "8.1.1",
    "turbo": "2.10.0",
    "typescript": "6.0.3"
  },
  "resolutions": {
    "yaml": "2.8.3",
    "vite": "8.0.12",
    "cacache": "20.0.4"
  },
  "lint-staged": {
    "{packages,apps,server}/**/*.{js,jsx,ts,tsx,cjs,mjs}": "eslint --cache --fix  --config packages/config/eslint/eslint.config.mjs",
    "*.{js,jsx,ts,tsx,cjs,mjs,json,yaml,yml,md,css}": "prettier --write",
    "*.css": "stylelint --fix"
  },
  "msw": {
    "workerDirectory": [
      "./.storybook/mock"
    ]
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
