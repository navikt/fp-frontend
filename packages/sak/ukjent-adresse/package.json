{
  "name": "@navikt/fp-sak-ukjent-adresse",
  "description": "Viser en info tekst som informerer saksbehandlere at brukeren i behandlingen har ikke en registrert adresse.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "build:storybook": "storybook build -o .storybook-static-build",
    "test": "vitest",
    "eslint": "eslint src/**/*.ts* --color",
    "eslint:fix": "eslint --fix src/**/*.ts* --color",
    "prettier:fix": "prettier --write src",
    "tsc": "tsc --noEmit",
    "clean": "rm -rf ./dist ./node_modules ./.turbo ./.storybook-static-build",
    "storybook": "storybook dev --quiet -p 7059"
  },
  "dependencies": {
    "@navikt/ds-react": "8.8.0",
    "@navikt/ft-utils": "3.11.13",
    "react": "19.2.4",
    "react-intl": "10.1.0"
  },
  "devDependencies": {
    "@navikt/fp-config-eslint": "workspace:*",
    "@navikt/fp-config-typescript": "workspace:*",
    "@navikt/fp-config-vite": "workspace:*",
    "@storybook/react": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "eslint": "9.39.4",
    "storybook": "10.3.3",
    "typescript": "5.9.3",
    "vite": "8.0.2",
    "vitest": "4.1.1"
  }
}
