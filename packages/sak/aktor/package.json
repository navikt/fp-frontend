{
  "name": "@navikt/fp-sak-aktor",
  "description": "Komponent som viser en liste med saker knyttet til en aktør-id",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "build:storybook": "storybook build -o .storybook-static-build",
    "test": "vitest",
    "eslint": "eslint src/**/*.ts* --color",
    "eslint:fix": "eslint --fix src/**/*.ts* --color",
    "prettier:fix": "prettier --write src",
    "tsc": "tsc --noEmit",
    "clean": "rm -rf ./dist ./node_modules ./.turbo ./.storybook-static-build",
    "storybook": "storybook dev --quiet -p 7040"
  },
  "dependencies": {
    "@navikt/aksel-icons": "8.10.1",
    "@navikt/ds-react": "8.10.1",
    "@navikt/fp-sak-visittkort": "workspace:*",
    "@navikt/fp-types": "workspace:*",
    "@navikt/ft-plattform-komponenter": "11.1.1",
    "@navikt/ft-ui-komponenter": "7.1.1",
    "@navikt/ft-utils": "4.1.1",
    "dayjs": "1.11.20",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-intl": "8.1.4"
  },
  "devDependencies": {
    "@navikt/fp-config-eslint": "workspace:*",
    "@navikt/fp-config-typescript": "workspace:*",
    "@navikt/fp-config-vite": "workspace:*",
    "@navikt/fp-storybook-utils": "workspace:*",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "eslint": "10.2.0",
    "storybook": "10.3.5",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
