{
  "app": "fp-frontend",
  "ingresses": ["https://fpsak.intern.dev.nav.no"],
  "minReplicas": "1",
  "maxReplicas": "2",
  "limits": {
    "mem": "256Mi"
  },
  "requests": {
    "cpu": "150m",
    "mem": "150Mi"
  },
  "env": "development",
  "groups": [
    {
      "uuid": "27e77109-fef2-48ce-a174-269074490353",
      "kommentar": "saksbehandler"
    },
    {
      "uuid": "8cddda87-0a22-4d35-9186-a2c32a6ab450",
      "kommentar": "veileder"
    }
  ],
  "outboundRules": [
    {
      "application": "fpmottak"
    },
    {
      "application": "fplos"
    }
  ],
  "externals": ["fpsak-api.dev-fss-pub.nais.io", "fptilbake.dev-fss-pub.nais.io"],
  "proxyRedirects": [
    {
      "path": "/fpsak/api",
      "url": "https://fpsak-api.dev-fss-pub.nais.io",
      "scope": "api://dev-fss.teamforeldrepenger.fpsak/.default"
    },
    {
      "path": "/fptilbake/api",
      "url": "https://fptilbake.dev-fss-pub.nais.io",
      "scope": "api://dev-fss.teamforeldrepenger.fptilbake/.default"
    },
    {
      "path": "/fplos/api",
      "url": "http://fplos",
      "scope": "api://dev-gcp.teamforeldrepenger.fplos/.default"
    },
    {
      "path": "/fpmottak/api",
      "url": "http://fpmottak",
      "scope": "api://dev-gcp.teamforeldrepenger.fpmottak/.default"
    }
  ],
  "viteModePort": "9010"
}
